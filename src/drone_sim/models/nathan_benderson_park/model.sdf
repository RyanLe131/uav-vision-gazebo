            <visual name="PalmTree_visual">
                <geometry>
                    <mesh>
                        <uri>model://nathan_benderson_park/meshes/nb_park.dae</uri>
                        <submesh>
                            <name>PalmTree</name>
                            <center>false</center>
                        </submesh>
                    </mesh>
                </geometry>
