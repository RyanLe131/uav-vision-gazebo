                    <diffuse>1.0 1.0 1.0</diffuse>
                    <specular>1.0 1.0 1.0</specular>
                    <pbr>
                        <metal>
                            <albedo_map>model://nathan_benderson_park/materials/textures/PalmTree_Albedo.png</albedo_map>
                            <normal_map>model://nathan_benderson_park/materials/textures/PalmTree_Normal.png</normal_map>
                            <roughness>1</roughness>
                        </metal>
                    </pbr>
                </material>
            </visual>
            <visual name="Asphalt_visual">
                <geometry>
                    <mesh>
                        <uri>model://nathan_benderson_park/meshes/nb_park.dae</uri>
                        <submesh>
                            <name>Asphalt</name>
                            <center>false</center>
                        </submesh>
                    </mesh>
                </geometry>
                <material>
                    <diffuse>1.0 1.0 1.0</diffuse>
                    <specular>0.06 0.06 0.06</specular>
                    <pbr>
                        <metal>
                            <albedo_map>model://nathan_benderson_park/materials/textures/Asphalt_Albedo.png</albedo_map>
                            <normal_map>model://nathan_benderson_park/materials/textures/Asphalt_Normal.png</normal_map>
