<?xml version="1.0" encoding="UTF-8"?>
<sdf version="1.6">
    <model name="nb_park">
        <static>true</static>
        <link name="base_link">
            <!-- Mesh collision for all structures (roads, buildings, docks, etc.)
                 This uses the full DAE mesh for accurate collision detection.
                 More computationally expensive but accurate. -->
            <collision name="mesh_collision">
                <geometry>
                    <mesh>
                        <uri>model://nathan_benderson_park/meshes/nb_park.dae</uri>
                    </mesh>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>1.0</mu>
                            <mu2>1.0</mu2>
                        </ode>
                    </friction>
                </surface>
            </collision>
            <visual name="Road_visual">
                <geometry>
                    <mesh>
                        <uri>model://nathan_benderson_park/meshes/nb_park.dae</uri>
                        <submesh>
                            <name>Road</name>
                            <center>false</center>
                        </submesh>
                    </mesh>
                </geometry>
                <material>
                    <diffuse>1.0 1.0 1.0</diffuse>
                    <specular>0.06 0.06 0.06</specular>
                    <pbr>
                        <metal>
                            <albedo_map>model://nathan_benderson_park/materials/textures/Road_Albedo.png</albedo_map>
                            <normal_map>model://nathan_benderson_park/materials/textures/Road_Normal.png</normal_map>
                            <roughness_map>model://nathan_benderson_park/materials/textures/Road_Roughness.png</roughness_map>
                            <environment_map>model://nathan_benderson_park/materials/textures/EnvMap.dds</environment_map>
                        </metal>
                    </pbr>
                </material>
            </visual>
            <visual name="Wall_visual">
                <geometry>
                    <mesh>
                        <uri>model://nathan_benderson_park/meshes/nb_park.dae</uri>
                        <submesh>
                            <name>Wall</name>
                            <center>false</center>
                        </submesh>
                    </mesh>
                </geometry>
                <material>
                    <diffuse>1.0 1.0 1.0</diffuse>
                    <specular>0.06 0.06 0.06</specular>
                    <pbr>
                        <metal>
                            <albedo_map>model://nathan_benderson_park/materials/textures/Wall_Albedo.png</albedo_map>
                            <normal_map>model://nathan_benderson_park/materials/textures/Wall_Normal.png</normal_map>
                            <roughness_map>model://nathan_benderson_park/materials/textures/Wall_Roughness.png</roughness_map>
                            <environment_map>model://nathan_benderson_park/materials/textures/EnvMap.dds</environment_map>
                        </metal>
                    </pbr>
                </material>
            </visual>
            <visual name="Dock_visual">
                <geometry>
                    <mesh>
                        <uri>model://nathan_benderson_park/meshes/nb_park.dae</uri>
                        <submesh>
                            <name>Dock</name>
                            <center>false</center>
                        </submesh>
                    </mesh>
                </geometry>
                <material>
                    <diffuse>1.0 1.0 1.0</diffuse>
                    <specular>0.06 0.06 0.06</specular>
                    <pbr>
                        <metal>
                            <albedo_map>model://nathan_benderson_park/materials/textures/Dock_Albedo.png</albedo_map>
                            <normal_map>model://nathan_benderson_park/materials/textures/Dock_Normal.png</normal_map>
                            <roughness_map>model://nathan_benderson_park/materials/textures/Dock_Roughness.png</roughness_map>
