                    </mesh>
                </geometry>
                <material>
                    <diffuse>1.0 1.0 1.0</diffuse>
                    <specular>1.0 1.0 1.0</specular>
                    <pbr>
                        <metal>
                            <albedo_map>model://nathan_benderson_park/materials/textures/Railing_Albedo.png</albedo_map>
                            <metalness_map>model://nathan_benderson_park/materials/textures/Railing_Metalness.png</metalness_map>
                            <roughness_map>model://nathan_benderson_park/materials/textures/Railing_Roughness.png</roughness_map>
