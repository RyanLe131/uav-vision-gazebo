                        <metal>
                            <albedo_map>model://nathan_benderson_park/materials/textures/Window_Albedo.png</albedo_map>
                            <normal_map>model://nathan_benderson_park/materials/textures/Wall_Normal.png</normal_map>
                            <roughness_map>model://nathan_benderson_park/materials/textures/Window_Roughness.png</roughness_map>
