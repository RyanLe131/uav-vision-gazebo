        </link>
        <link name="heightmap">
            <!-- Box collision replaces heightmap collision because Gazebo Harmonic
                 physics engines (dart, bullet, bullet-featherstone) do not support
                 heightmap collision. This flat box provides ground collision. -->
            <collision name="ground_collision">
                <pose>0 0 -1 0 0 0</pose>
                <geometry>
                    <box>
                        <size>1724.5 3449 2</size>
                    </box>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>1.0</mu>
                            <mu2>1.0</mu2>
                        </ode>
                    </friction>
                </surface>
            </collision>
            <visual name="heightmap_visual">
                <geometry>
                    <heightmap>
                        <use_terrain_paging>false</use_terrain_paging>
                        <texture>
                            <diffuse>model://nathan_benderson_park/materials/textures/Sand_Albedo.png</diffuse>
                            <normal>model://nathan_benderson_park/materials/textures/flat_normal.png</normal>
                            <size>10</size>
                        </texture>
                        <texture>
                            <diffuse>model://nathan_benderson_park/materials/textures/Grass_Albedo.jpg</diffuse>
                            <normal>model://nathan_benderson_park/materials/textures/flat_normal.png</normal>
                            <size>10</size>
                        </texture>
                        <blend>
                            <min_height>4</min_height>
                            <fade_dist>1</fade_dist>
                        </blend>
                        <uri>model://nathan_benderson_park/materials/textures/Heightmap.png</uri>
                        <size>1724.5 3449 7</size>
                        <pos>0 0 -2.548</pos>
                    </heightmap>
                </geometry>
            </visual>
        </link>
    </model>
</sdf>
